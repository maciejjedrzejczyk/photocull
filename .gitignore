# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
.eggs/
*.egg-info/
build/
dist/

# Tool output & cache — never commit scan results or the cache DB
*.sqlite
*.sqlite-journal
.photo_quality_cache.sqlite
photo_quality_report.csv
*_report.csv

# Never commit photos / image data. Image files are ignored at the repo root
# (where stray scans/outputs land). Docs screenshots under assets/ or docs/
# are still allowed, or force-add with `git add -f`.
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.bmp
/*.tif
/*.tiff
/*.webp
/*.heic
/*.heif
/*.dng

# macOS / editors
.DS_Store
.idea/
.vscode/
